// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ProfessionalStatus {
  ACTIVE
  INACTIVE
}

enum PaymentStatus {
  DRAFT
  PENDING_APPROVAL
  PAID
  REJECTED
}

enum UserRole {
  CORP_ADMIN
  UNIT_OPERATOR
  AUDITOR
}

model Tenant {
  id        String   @id @default(uuid())
  name      String
  document  String   @unique // CNPJ
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users         User[]
  professionals Professional[]
  taxConfigs    TaxConfig[]
  payments      Payment[]
  auditLogs     TenantAuditLog[]
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  password  String?  // nullable if using Keycloak/LDAP exclusively
  role      UserRole @default(UNIT_OPERATOR)
  tenantId  String?  // nullable for CORP/AUDIT
  tenant    Tenant?  @relation(fields: [tenantId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  auditLogs     ProfessionalAuditLog[]
  tenantLogs    TenantAuditLog[]
}

model Professional {
  id             String   @id @default(uuid())
  name           String
  document       String   @unique // CPF
  identity       String?  // Identidade
  issuer         String?  // Orgao Emissor
  pisVoter       String?  // PIS/PASEP/NIT
  numDependents  Int      @default(0)
  gender         String?  // Sexo
  
  zip            String?  // CEP
  address        String?  // Endereco
  neighborhood   String?  // Bairro
  city           String?  // Cidade
  phone          String?  // Telefone
  mobile         String?  // Celular
  email          String?  // Email

  bank           String?  // Banco
  agency         String?  // Agencia
  account        String?  // Conta

  status         ProfessionalStatus @default(ACTIVE)
  
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id])
  payments       Payment[]
  
  inssSources    ExternalInssSource[]
  legalDeds      LegalDeduction[]
  auditLogs      ProfessionalAuditLog[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model ExternalInssSource {
  id             String   @id @default(uuid())
  professionalId String
  professional   Professional @relation(fields: [professionalId], references: [id])
  companyName    String
  cnpj           String
  amount         Decimal  @db.Decimal(10, 2)
  competence     String   // e.g. "02/2026"
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model LegalDeduction {
  id             String   @id @default(uuid())
  professionalId String
  professional   Professional @relation(fields: [professionalId], references: [id])
  type           String   // e.g. ALIMONY, PENSION
  amount         Decimal  @db.Decimal(10, 2)
  description    String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model ProfessionalAuditLog {
  id             String   @id @default(uuid())
  professionalId String
  professional   Professional @relation(fields: [professionalId], references: [id])
  action         String   // e.g. DEACTIVATE, REACTIVATE, EDIT
  reason         String?
  performedById  String
  performedBy    User     @relation(fields: [performedById], references: [id])
  snapshotMap    Json?    // Snapshot of the previous state
  createdAt      DateTime @default(now())
}

model TaxConfig {
  id             String   @id @default(uuid())
  year           Int
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id])

  // INSS settings
  inssRate       Decimal  @db.Decimal(5, 4) // e.g. 0.1100 for 11%
  inssCeiling    Decimal  @db.Decimal(10, 2) // e.g. 932.32
  
  // Dependent deduction
  dependentDeduction Decimal @db.Decimal(10, 2) // e.g. 189.59
  
  // IRRF settings (using JSONB for flexibility across multiple rules)
  irrfBrackets   Json     // Array of { min: number, max: number, rate: number, deduction: number }

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  payments       Payment[]
  
  @@unique([tenantId, year])
}

model Payment {
  id             String   @id @default(uuid())
  code           String   @unique
  competence     String   // e.g. "02/2026"
  paymentDate    DateTime

  grossValue     Decimal  @db.Decimal(10, 2)
  inssValue      Decimal  @db.Decimal(10, 2)
  irrfValue      Decimal  @db.Decimal(10, 2)
  netValue       Decimal  @db.Decimal(10, 2)
  status         PaymentStatus @default(DRAFT)
  convenio       String?

  professionalId String
  professional   Professional @relation(fields: [professionalId], references: [id])
  
  tenantId       String
  tenant         Tenant       @relation(fields: [tenantId], references: [id])

  tenantConfigId String?
  
  taxConfigId    String
  taxConfig      TaxConfig    @relation(fields: [taxConfigId], references: [id])

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model TenantAuditLog {
  id             String   @id @default(uuid())
  tenantId       String?  // nullable se for ação puramente corporativa cross-tenant
  tenant         Tenant?  @relation(fields: [tenantId], references: [id])
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  action         String   // ex: "SWITCH_CONTEXT", "EDIT_TAX_RULES", "VIEW_GLOBAL_DASHBOARD", "PROVISION_TENANT"
  resource       String?  // ex: "/tax/config", "tenant_ufrj"
  ipAddress      String?
  userAgent      String?
  metadata       Json?    // Snapshot da ação ou diff
  createdAt      DateTime @default(now())
}

